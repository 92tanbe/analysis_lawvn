# Sao chep file nay sang `.env` va dien gia tri thuc.
# Khi deploy len FastAPI Cloud: dien cac bien nay qua dashboard "Environment Variables"
# (KHONG commit file .env that su).

# ----- Neo4j (Aura) -----
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password
# Chi khi Neo4j chay tren may ban (bolt://localhost:7687):
# NEO4J_ALLOW_LOCALHOST=true
# NEO4J_DATABASE=neo4j   # optional, mac dinh dung database default

# ----- OpenAI -----
OPENAI_API_KEY=sk-your-key
OPENAI_MODEL=gpt-4o-mini

# ----- Embedding (BKAI bi-encoder, local) -----
EMBEDDING_MODEL=bkai-foundation-models/vietnamese-bi-encoder
EMBEDDING_DIM=768
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32

# ----- Reranker (cross-encoder, local) -----
# Tat de tiet kiem RAM khi deploy serverless
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
ENABLE_RERANKER=true
RERANKER_TOP_K=8

# ----- Hugging Face token (giup tai model nhanh hon, tranh rate limit) -----
# Lay tai https://huggingface.co/settings/tokens
HF_TOKEN=

# ----- Retrieval (tunable) -----
RRF_K=60
TOP_K_DIEU=10
TOP_K_KHOAN=20
TOP_K_FULLTEXT=10
CANDIDATE_TOP_K=30

# ----- Server -----
CHATBOT_HOST=0.0.0.0
CHATBOT_PORT=8001
LOG_LEVEL=INFO

# CORS - them domain frontend cua ban (cach nhau bang dau phay)
CHATBOT_CORS_ORIGINS=http://localhost:5173,http://localhost:8000,https://lex-bot-datn.vercel.app
